# Copy to .env and fill in real values. .env is gitignored.

# === Google OAuth ===
# From https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Mailjet ===
# From https://app.mailjet.com/account/apikeys
MAILJET_API_KEY=
MAILJET_API_SECRET=
MAILJET_FROM_EMAIL=triprjt@gmail.com
MAILJET_FROM_NAME=ViralFinder

# === Site ===
SITE_URL=http://localhost:8000
SESSION_SECRET=change_me_to_random_32_byte_hex
